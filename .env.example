# ─── IFRTEST.ca Stripe Server — Environment Variables ───────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub — it contains secret keys.

# ── Stripe API Keys ──────────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
# Use TEST keys (sk_test_...) while building, LIVE keys (sk_live_...) for real payments.
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_SECRET_KEY

# ── Stripe Price IDs ─────────────────────────────────────────────────────────
# Get these after creating your products in Stripe Dashboard → Products.
# Each price has an ID starting with "price_"
STRIPE_MONTHLY_PRICE_ID=price_REPLACE_WITH_MONTHLY_PRICE_ID
STRIPE_LIFETIME_PRICE_ID=price_REPLACE_WITH_LIFETIME_PRICE_ID

# ── Stripe Webhook Secret ────────────────────────────────────────────────────
# Get this from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# Leave blank during local development (webhook verification is skipped if empty).
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_WEBHOOK_SECRET

# ── Frontend URL ─────────────────────────────────────────────────────────────
# Where your HTML files are served from.
# Development:  http://localhost:8080
# Production:   https://ifrtest.ca
# Multiple:     https://ifrtest.ca,https://www.ifrtest.ca
FRONTEND_URL=http://localhost:8080

# ── Server Port ──────────────────────────────────────────────────────────────
# Railway sets this automatically. Only needed for local development.
PORT=3001
